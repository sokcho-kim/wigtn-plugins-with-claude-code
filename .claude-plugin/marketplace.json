      "skills": [
        "./skills/auto-commit"
      ]
    },
    {
      "name": "prd",
      "description": "PRD 문서 자동 생성",
      "source": "./plugins/prd",
      "strict": false,
      "skills": [
        "./skills/prd"
      ]
    },
    {
      "name": "implement",
      "description": "PRD 기반 즉시 구현",
      "source": "./plugins/implement",
      "strict": false,
      "skills": [
        "./skills/implement"
      ]
    },
    {
      "name": "orchestrator-core",
      "description": "멀티 플러그인 오케스트레이션 코디네이터",
      "source": "./plugins/orchestrator-core",
      "strict": false,
      "skills": [
        "./skills/orchestration-protocol"
      ]
    },
    {
      "name": "stack-prisma",
