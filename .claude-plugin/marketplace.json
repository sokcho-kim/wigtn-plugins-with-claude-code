    {
      "name": "skill-typescript",
      "description": "TypeScript 패턴 (유틸리티 타입, DTO, API 응답)",
      "source": "./plugins/skill-typescript",
      "strict": false,
      "skills": [
        "./skills/utility-types",
        "./skills/dto-patterns",
        "./skills/api-response-types"
      ]
    },
    {
      "name": "skill-zod",
      "description": "Zod 스키마 검증 패턴",
      "source": "./plugins/skill-zod",
