    },
    {
      "name": "stack-admin",
      "description": "어드민 대시보드 (데이터 테이블, 차트)",
      "source": "./plugins/stack-admin",
      "strict": false,
      "skills": [
        "./skills/admin-layouts",
        "./skills/data-tables",
        "./skills/charts"
      ]
    },
    {
      "name": "stack-infra",
      "description": "인프라/DevOps (Docker, CI/CD)",
