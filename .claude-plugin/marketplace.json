{
  "name": "wigtn-plugins",
  "owner": {
    "name": "wigtn",
    "url": "https://github.com/wigtn"
  },
  "metadata": {
    "description": "Claude Code development workflow plugins",
    "version": "1.0.0"
  },
  "plugins": [
    {
      "name": "auto-commit",
      "description": "변경사항 분석 후 자동 커밋",
