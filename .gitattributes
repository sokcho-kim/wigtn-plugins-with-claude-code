# 모든 텍스트 파일을 LF로 통일
* text=auto eol=lf

# 명시적으로 텍스트 파일 지정
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf
*.env text eol=lf

# 바이너리 파일은 변환하지 않음
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Windows 배치 파일은 CRLF 유지 (필요시)
# *.bat text eol=crlf
# *.cmd text eol=crlf

