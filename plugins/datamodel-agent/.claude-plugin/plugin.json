{
  "name": "datamodel-agent",
  "version": "1.0.0",
  "description": "Database schema and migration specialist. Manages Prisma schema, migrations, and data modeling with enforced ownership boundaries.",
  "author": {
    "name": "wigtn",
    "url": "https://github.com/wigtn"
  },
  "repository": "https://github.com/wigtn/wigtn-plugins-with-claude-code",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "agent",
    "prisma",
    "database",
    "schema",
    "migration",
    "data-modeling"
  ],
  "skills": ["./skills/datamodel"],
  "dependsOn": "agent-orchestration",
  "agentType": "domain",
  "tier": 1,
  "ownership": {
    "writable": [
      "/packages/db/schema.prisma",
      "/packages/db/migrations/**",
      "/packages/db/seed/**"
    ],
    "readable": [
      "/packages/contracts/**"
    ],
    "forbidden": [
      "/apps/**"
    ]
  }
}
