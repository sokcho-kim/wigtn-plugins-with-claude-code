{
  "name": "stack-nextjs",
  "version": "1.0.0",
  "description": "Next.js frontend web application plugin. Provides webapp-agent for App Router pages, Server/Client Components, hooks, and UI.",
  "author": {
    "name": "wigtn",
    "url": "https://github.com/wigtn"
  },
  "repository": "https://github.com/wigtn/wigtn-plugins-with-claude-code",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "nextjs",
    "react",
    "frontend",
    "app-router",
    "server-components"
  ],
  "agents": "./agents",
  "skills": [
    "./skills/nextjs-routing",
    "./skills/react-components",
    "./skills/react-hooks",
    "./skills/server-actions",
    "./skills/tailwind-ui"
  ],
  "orchestration": {
    "tier": 2,
    "ownership": [
      "/apps/web/**"
    ],
    "capabilities": [
      "app-router",
      "server-components",
      "client-components",
      "data-fetching",
      "ui-components"
    ],
    "dependencies": [
      "stack-prisma"
    ],
    "parallelWith": [
      "stack-nestjs",
      "stack-admin"
    ],
    "produces": [
      "pages",
      "components",
      "hooks"
    ]
  }
}
